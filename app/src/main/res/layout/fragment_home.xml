<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/content_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Dashboard Admin Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dashboard Admin"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ringkasan data dan aktivitas sistem"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="admin"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Role: admin"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Stats Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Stat 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL WARGA" android:textColor="@color/gray_text" android:textSize="10sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/black" android:textSize="24sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data warga terdaftar" android:textColor="@color/gray_text" android:textSize="10sp" />
                </LinearLayout>
                <!-- Stat 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="USER SISTEM" android:textColor="@color/gray_text" android:textSize="10sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/black" android:textSize="24sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Admin &amp; operator aktif" android:textColor="@color/gray_text" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Stat 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PROGRAM BINA DESA" android:textColor="@color/gray_text" android:textSize="10sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/black" android:textSize="24sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Program berjalan" android:textColor="@color/gray_text" android:textSize="10sp" />
                </LinearLayout>
                <!-- Stat 4 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOG AKTIVITAS" android:textColor="@color/gray_text" android:textSize="10sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/black" android:textSize="24sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aktivitas terbaru hari ini" android:textColor="@color/gray_text" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Activity and System Summary Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <!-- Aktivitas Terbaru -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aktivitas Terbaru" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Log sistem terakhir" android:textColor="@color/gray_text" android:textSize="12sp" />
                </RelativeLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color" />
                <TextView android:layout_width="match_parent" android:layout_height="150dp" android:gravity="center" android:padding="20dp" android:text="Belum ada aktivitas terbaru." android:textColor="@color/gray_text" />
            </LinearLayout>

            <!-- Ringkasan Sistem -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:text="Ringkasan Sistem" android:textStyle="bold" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Versi Aplikasi" android:textColor="@color/gray_text" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="v1.0.0" android:textColor="@color/black" />
                    </RelativeLayout>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terakhir Login" android:textColor="@color/gray_text" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="05 May 2026 16:20" android:textColor="@color/black" />
                    </RelativeLayout>
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Role Saat Ini" android:textColor="@color/gray_text" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="ADMIN" android:textColor="@color/black" />
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Aksi Cepat / Pertemuan Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:text="Aksi Cepat &amp; Tugas" android:textStyle="bold" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:columnCount="2">

                    <Button android:id="@+id/btn_pertemuan2" android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#6c757d" android:text="Pertemuan 2" android:textAllCaps="false" android:textSize="10sp" app:cornerRadius="8dp" />
                    <Button android:id="@+id/btn_pertemuan3" android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#6c757d" android:text="Pertemuan 3" android:textAllCaps="false" android:textSize="10sp" app:cornerRadius="8dp" />
                    <Button android:id="@+id/btn_pertemuan4" android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#6c757d" android:text="Pertemuan 4" android:textAllCaps="false" android:textSize="10sp" app:cornerRadius="8dp" />
                    <Button android:id="@+id/btn_pertemuan5" android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#6c757d" android:text="Pertemuan 5" android:textAllCaps="false" android:textSize="10sp" app:cornerRadius="8dp" />
                    <Button android:id="@+id/btn_pertemuan7" android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#6c757d" android:text="Pertemuan 7" android:textAllCaps="false" android:textSize="10sp" app:cornerRadius="8dp" />
                    <Button android:id="@+id/btn_logout_home" android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:layout_margin="4dp" android:backgroundTint="#e53935" android:text="Logout" android:textAllCaps="false" android:textSize="10sp" app:cornerRadius="8dp" />
                </GridLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Footer -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="© 2026 Inventaris &amp; Aset." android:textColor="@color/gray_text" android:textSize="12sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="Inventaris &amp; Aset" android:textColor="@color/gray_text" android:textSize="12sp" />
        </RelativeLayout>

    </LinearLayout>
</ScrollView>